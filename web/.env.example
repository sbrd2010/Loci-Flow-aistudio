# Loci web environment example
# Copy this file to web/.env for local development only.
# Do not commit real API keys or service-account credentials.

# Optional built-in AI provider keys for private alpha/testing.
# Public web builds expose VITE_* values in the browser bundle.
VITE_GROQ_KEY=replace-with-groq-api-key
VITE_NVIDIA_KEY=replace-with-nvidia-api-key
VITE_GEMINI_KEY=replace-with-gemini-api-key
VITE_CEREBRAS_KEY=replace-with-cerebras-api-key
# Optional, non-secret: override the default Cerebras model (defaults to gpt-oss-120b).
VITE_CEREBRAS_MODEL=gpt-oss-120b

# Optional Firebase/analytics overrides.
# Firebase web config values are public client config, not service-account secrets.
VITE_FIREBASE_APP_ID=replace-with-firebase-web-app-id
VITE_GA_MEASUREMENT_ID=replace-with-ga-measurement-id
