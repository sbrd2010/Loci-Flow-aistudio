{
  "rules": {
    "sync": {
      "$userId": {
        ".read":  "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId",
        ".validate": "newData.hasChildren(['userId', 'tasks', 'config'])",
        "userId": {
          ".validate": "newData.isString() && newData.val().length <= 200"
        },
        "tasks": {
          "$taskIdx": {
            ".validate": "newData.hasChildren(['id', 'title', 'userId'])",
            "title": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 300"
            },
            "concreteStep": {
              ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 300)"
            },
            "$other": { ".validate": true }
          }
        },
        "config": {
          ".validate": "newData.hasChildren(['userId'])",
          "intentionMessage": {
            ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 500)"
          },
          "userName": {
            ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 100)"
          },
          "mentorName": {
            ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 100)"
          },
          "deadlineLabel": {
            ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 100)"
          },
          "$other": { ".validate": true }
        },
        "chatHistory": {
          "$msgIdx": {
            "text":   { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 5000)" },
            "isUser": { ".validate": "!newData.exists() || newData.isBoolean()" },
            "$other": { ".validate": false }
          }
        },
        "contributions": { ".validate": true },
        "brainDump":     { ".validate": true },
        "brainDumpUpdatedAt": { ".validate": "!newData.exists() || newData.isNumber()" },
        "timestamp":     { ".validate": "!newData.exists() || newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },
    "bugReports": {
      ".read": false,
      "$reportId": {
        ".write": "auth != null && !data.exists() && auth.uid === newData.child('userId').val()",
        ".validate": "newData.hasChildren(['what', 'userId', 'submittedAt'])",
        "what":       { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 2000" },
        "steps":      { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 2000)" },
        "device":     { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 300)" },
        "userId":     { ".validate": "newData.isString() && newData.val().length <= 200" },
        "userEmail":  { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 200)" },
        "appVersion": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 80)" },
        "submittedAt":{ ".validate": "newData.isNumber()" },
        "$other":     { ".validate": false }
      }
    },
    "$other": {
      ".read":  false,
      ".write": false
    }
  }
}
